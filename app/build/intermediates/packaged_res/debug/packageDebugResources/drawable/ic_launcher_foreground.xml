<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="54"
        android:translateY="54">

        <!-- Subtle Outer Glow/Shadow for the Main Icon -->
        <path
            android:fillColor="#20000000"
            android:pathData="M0,-32 C0,-32 28,-15 28,15 C28,38 0,48 0,48 C0,48 -28,38 -28,15 C-28,-15 0,-32 0,-32 Z"
            android:translateX="2"
            android:translateY="2" />

        <!-- Main Leaf Body (Sokogarden) -->
        <path
            android:pathData="M0,-30 C0,-30 25,-15 25,15 C25,35 0,45 0,45 C0,45 -25,35 -25,15 C-25,-15 0,-30 0,-30 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="0"
                    android:startY="-30"
                    android:endX="0"
                    android:endY="45"
                    android:type="linear">
                    <item android:offset="0" android:color="#FFFFFF" />
                    <item android:offset="1" android:color="#F1F8E9" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- The Yoghurt Droplet (DailyYoghurts) -->
        <path
            android:pathData="M0,-5 C0,-5 18,10 18,28 C18,40 0,48 0,48 C0,48 -18,40 -18,28 C-18,10 0,-5 0,-5 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="0"
                    android:startY="-5"
                    android:endX="0"
                    android:endY="48"
                    android:type="linear">
                    <item android:offset="0" android:color="#E3F2FD" />
                    <item android:offset="1" android:color="#BBDEFB" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Droplet "Creamy" Highlight -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M-8,22 C-8,18 -5,15 -1,15"
            android:strokeWidth="2.5"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round"
            android:alpha="0.8" />

        <!-- Leaf Vein Detail (Abstract) -->
        <path
            android:strokeColor="#A5D6A7"
            android:strokeWidth="1"
            android:pathData="M0,-20 L0,5"
            android:strokeLineCap="round"
            android:alpha="0.5"/>

    </group>

    <!-- Floating "Freshness" Sparkles -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M80,30 L82,28 L80,26 L78,28 Z"
        android:alpha="0.6" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M25,45 L27,43 L25,41 L23,43 Z"
        android:alpha="0.4" />

</vector>